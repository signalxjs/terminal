{
    "name": "@sigx/runtime-terminal",
    "version": "0.6.1",
    "description": "Terminal renderer for SignalX",
    "type": "module",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/index.js",
            "types": "./dist/index.d.ts"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "vite build && tsgo --emitDeclarationOnly",
        "dev": "vite build --watch"
    },
    "keywords": [
        "sigx",
        "signalx",
        "terminal",
        "tui",
        "cli",
        "console"
    ],
    "author": "Andreas Ekdahl",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/signalxjs/terminal.git",
        "directory": "packages/runtime-terminal"
    },
    "homepage": "https://sigx.dev/terminal/",
    "bugs": {
        "url": "https://github.com/signalxjs/terminal/issues"
    },
    "dependencies": {
        "@sigx/reactivity": ">=0.6.0 <0.7.0",
        "@sigx/runtime-core": ">=0.6.0 <0.7.0"
    },
    "devDependencies": {
        "@sigx/vite": "^0.4.7",
        "@types/node": "^22.0.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.3"
    },
    "publishConfig": {
        "access": "public"
    }
}
