{
  "name": "sigx-terminal",
  "version": "0.4.1",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "SignalX Terminal — TUI framework with TSX support (terminal + runtime-terminal)",
  "type": "module",
  "scripts": {
    "wt": "node scripts/worktree.mjs",
    "build": "pnpm --filter @sigx/args run build && pnpm --filter @sigx/runtime-terminal run build && pnpm --filter @sigx/terminal-zero run build && pnpm --filter @sigx/terminal-ui run build && pnpm --filter @sigx/terminal run build && pnpm --filter @sigx/terminal-dev run build",
    "dev": "pnpm build && cd examples/showcase && node ../../packages/terminal-dev/dist/cli.js src/main.tsx",
    "showcase": "cd examples/showcase && node --import tsx src/main.tsx",
    "wizard": "cd examples/create-wizard && node --import tsx src/main.tsx",
    "build-sim": "cd examples/build-sim && node --import tsx src/main.tsx",
    "inline-counter": "cd examples/inline-counter && node --import tsx src/main.tsx",
    "static-log": "cd examples/static-log && node --import tsx src/main.tsx",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:coverage": "vitest run --passWithNoTests --coverage",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint packages/args/src packages/runtime-terminal/src packages/terminal-zero/src packages/terminal-ui/src packages/terminal/src packages/terminal-dev/src",
    "lint:fix": "oxlint --fix packages/args/src packages/runtime-terminal/src packages/terminal-zero/src packages/terminal-ui/src packages/terminal/src packages/terminal-dev/src",
    "publish:dry": "node scripts/publish.js --dry-run",
    "publish:all": "node scripts/publish.js",
    "publish:beta": "node scripts/publish.js --tag beta",
    "verify:pack": "node scripts/verify-pack.js",
    "version:set": "node scripts/bump-version.js",
    "version:patch": "node scripts/bump-version.js patch",
    "version:minor": "node scripts/bump-version.js minor",
    "version:major": "node scripts/bump-version.js major",
    "clean": "node -e \"const fs=require('fs'),p=require('path');const rm=x=>fs.rmSync(x,{recursive:true,force:true});for(const d of fs.readdirSync('packages')){rm(p.join('packages',d,'dist'));rm(p.join('packages',d,'node_modules'));}rm('node_modules');rm('pnpm-lock.yaml');\"",
    "dashboard": "cd examples/dev-dashboard && node --import tsx src/main.tsx",
    "claude-shell": "cd examples/claude-shell && node --import tsx src/main.tsx",
    "version:check": "node scripts/check-versions.js"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript/native-preview": "7.0.0-dev.20260517.1",
    "@vitest/coverage-v8": "^4.1.8",
    "happy-dom": "^20.10.3",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "SignalX",
    "sigx",
    "terminal",
    "tui",
    "cli",
    "tsx"
  ],
  "author": "Andreas Ekdahl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/signalxjs/terminal.git"
  },
  "homepage": "https://sigx.dev/terminal/",
  "bugs": {
    "url": "https://github.com/signalxjs/terminal/issues"
  }
}
